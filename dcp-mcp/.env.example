# ──────────────────────────────────────────────────────
# DCP-MCP Configuration
# ──────────────────────────────────────────────────────

# Path to templates directory.
# Absolute path, or relative to the dcp-mcp/ directory.
# Default: ../templates  (works when running inside the DCP repo)
TEMPLATES_PATH=../templates

# Server mode: "local" or "hosted"
# Local mode reads templates from the local filesystem. No network calls.
DCP_MODE=local

# ──────────────────────────────────────────────────────
# Hosted mode (future — not yet implemented)
# ──────────────────────────────────────────────────────
# DCP_SERVER_URL=https://dcp.yourfirm.com
# DCP_API_KEY=your_key_here

# ──────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────

# Override the server name shown in MCP clients
# DCP_SERVER_NAME=DCP Policy Server
